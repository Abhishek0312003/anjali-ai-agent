# ── FreJun / Teler ──────────────────────────────────────────────────────
TELER_API_KEY=your_teler_api_key_here
TELER_FROM_NUMBER=+918065179538

# ── Deepgram (STT) ────────────────────────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key_here
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=hi-en            # hi-en = Hindi+English code-mix (Hinglish)

# ── OpenAI ───────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# ── Sarvam AI (TTS) — bulbul:v2 + arjun voice ────────────────────────
SARVAM_API_KEY=your_sarvam_api_key_here
SARVAM_TTS_MODEL=bulbul:v2         # v2 = better quality, better Hinglish
SARVAM_SPEAKER=abhilash               # Male voice — matches Abhishek persona
SARVAM_LANGUAGE=hi-IN
SARVAM_SAMPLE_RATE=8000

# ── Server ───────────────────────────────────────────────────────────
PUBLIC_HOST=your-ngrok-or-domain.ngrok-free.app    # No https://, no trailing slash
PORT=8000

# ── CRM Webhook (optional) ────────────────────────────────────────────
CRM_WEBHOOK_URL=                   # Leave empty to disable
